NODE_ENV=development
PORT=3000

MONGODB_URI=mongodb://127.0.0.1:27017/inventory-management
REDIS_URL=redis://127.0.0.1:6379
# Production (Upstash): rediss://default:PASSWORD@YOUR-ENDPOINT.upstash.io:6379

# Local dev
# CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# Production (DigitalOcean) — trailing slash is OK

MAX_TENANTS=20
MAX_USERS_PER_TENANT=20


JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

LOG_LEVEL=info
LOG_FORMAT=pretty
LOG_SLOW_MS=500

# Email (Resend) — forgot-password flow
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM="POS System <noreply@yourdomain.com>"
FRONTEND_URL=http://localhost:3001
PASSWORD_RESET_EXPIRES_MINUTES=15

# Demo login (after BE: npm run seed:demo)
# Email: demo@possimplify.com  Password: Demo12345!

# cd backend-inventory-management

# # Lần đầu (tạo tenant + toàn bộ data)
# npm run seed:demo

